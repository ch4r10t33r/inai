# Copy to .env and fill in to enable live LLM mode.
# Without these keys the example runs in demo mode (no LLMs needed).

# Enables Google ADK → Gemini 2.0 Flash for ResearchAgent
GOOGLE_API_KEY=

# Enables CrewAI → GPT-4o-mini for WriterAgent
OPENAI_API_KEY=

# Optional: override the default research topic
# RESEARCH_TOPIC=quantum computing breakthroughs 2024
